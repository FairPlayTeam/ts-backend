NODE_ENV=development
PORT=3000
DATABASE_URL="postgresql://myuser:mypass@localhost:5432/mydb?schema=public"
BASE_URL="http://localhost:3000"
TRUST_PROXY=loopback
FRONTEND_URL="http://localhost:5173"
PLAYBACK_TOKEN_SECRET="replace-with-a-long-random-secret"
PLAYBACK_TOKEN_TTL_SECONDS=3600
MINIO_URL="http://minio:minio123@localhost:6767"
BCRYPT_ROUNDS=12
CORS_ORIGINS="http://localhost:3000,http://localhost:5173"
JSON_BODY_LIMIT_BYTES=1048576
URLENCODED_BODY_LIMIT_BYTES=262144
CLEANUP_INTERVAL_MINUTES=60
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER="smtp-user"
SMTP_PASS="smtp-password"
SMTP_FROM="noreply@example.com"
