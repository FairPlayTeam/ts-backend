{
  "name": "fairplay-api",
  "version": "0.1.0",
  "private": false,
  "description": "Fairplay backend API built with TypeScript, Express, Prisma, MinIO, and Bun.",
  "license": "AGPL-3.0-only",
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "tsc",
    "start": "bun dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "check": "bun run typecheck && bun run test",
    "postinstall": "bunx prisma generate",
    "prisma:generate": "bunx prisma generate",
    "prisma:migrate": "bun run prisma:migrate:dev",
    "prisma:migrate:dev": "bunx prisma migrate dev",
    "prisma:migrate:deploy": "bunx prisma migrate deploy",
    "prisma:migrate:status": "bunx prisma migrate status",
    "prisma:studio": "bunx prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^5.19.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "file-type": "^21.0.0",
    "fluent-ffmpeg": "^2.1.3",
    "jsonwebtoken": "^9.0.2",
    "minio": "^8.0.1",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.3",
    "pm2": "^6.0.14",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/fluent-ffmpeg": "^2.1.25",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/minio": "^7.1.1",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.14.12",
    "@types/nodemailer": "^7.0.11",
    "@types/uuid": "^10.0.0",
    "prisma": "^5.19.1",
    "typescript": "^5.6.2"
  }
}
